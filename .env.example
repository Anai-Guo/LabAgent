# Lab Harness Configuration
# Copy to .env and fill in your values.

# AI Model Provider: anthropic, openai, ollama
LABHARNESS_PROVIDER=anthropic

# Model name
LABHARNESS_MODEL=claude-sonnet-4-20250514

# API key (for cloud models)
LABHARNESS_API_KEY=

# Base URL (for local models, e.g. Ollama)
# LABHARNESS_BASE_URL=http://localhost:11434

# Data output directory
LABHARNESS_DATA_DIR=./data
